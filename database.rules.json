{
  "rules": {
    "quizBattlePresence": {
      "$scope": {
        "$resourceId": {
          "$uid": {
            ".read": "auth != null && auth.uid === $uid",
            ".write": "auth != null && auth.uid === $uid"
          }
        }
      }
    },
    ".read": false,
    ".write": false
  }
}
