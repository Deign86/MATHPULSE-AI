{
  "rules": {
    "quizBattlePresence": {
      "$scope": {
        ".validate": "$scope.matches(/^[A-Za-z0-9_-]{1,32}$/)",
        "$resourceId": {
          ".validate": "$resourceId.matches(/^[A-Za-z0-9_-]{1,64}$/)",
          "$uid": {
            ".read": "auth != null && auth.uid === $uid",
            ".write": "auth != null && auth.uid === $uid",
            ".validate": "newData.val() == null || newData.hasChildren(['studentId', 'scope', 'resourceId', 'online', 'updatedAt'])",
            "studentId": {
              ".validate": "newData.isString() && newData.val().length >= 1"
            },
            "scope": {
              ".validate": "newData.isString() && newData.val().matches(/^(queue|room|match)$/)"
            },
            "resourceId": {
              ".validate": "newData.isString() && newData.val().length >= 1"
            },
            "online": {
              ".validate": "newData.isBoolean()"
            },
            "heartbeatAt": {
              ".validate": "newData.isNumber() && newData.val() > 0"
            },
            "updatedAt": {
              ".validate": "newData.isNumber() && newData.val() > 0"
            },
            "disconnectedAt": {
              ".validate": "newData.isNumber() && newData.val() > 0"
            },
            "displayName": {
              ".validate": "newData.isString() && newData.val().length <= 64"
            },
            "$other": {
              ".validate": false
            }
          }
        }
      }
    },
    ".read": false,
    ".write": false
  }
}
