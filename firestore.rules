rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // Defensive role function - handles missing user documents
    function role() {
      return isSignedIn() && userDoc() != null && userDoc().data.role != null
        ? userDoc().data.role
        : 'student';  // Default to student role for unauthenticated or missing role
    }

    function isAdmin() {
      return isSignedIn() && role() == 'admin';
    }

    function isTeacher() {
      return isSignedIn() && role() == 'teacher';
    }

    function isTeacherOrAdmin() {
      return isSignedIn() && (role() == 'teacher' || role() == 'admin');
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function ownerInExisting(field) {
      return resource != null && resource.data[field] == request.auth.uid;
    }

    function ownerInIncoming(field) {
      return request.resource != null && request.resource.data[field] == request.auth.uid;
    }

    function ownerByField(field) {
      return isSignedIn() && (ownerInExisting(field) || ownerInIncoming(field));
    }

    match /users/{userId} {
      allow create: if isSelf(userId);
      allow read: if isSelf(userId) || isTeacherOrAdmin();
      allow update: if isSelf(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Tutor Memory (profile, sessions, working state — written by backend, read by self) ──
    // Backend writes via Firebase Admin SDK (bypasses rules); students can also read their own
    match /users/{userId}/tutorMemory/{memoryPath=**} {
      allow read: if isSelf(userId) || isTeacherOrAdmin();
      allow write: if isSelf(userId) || isTeacherOrAdmin();  // Students can write (backend also writes via Admin SDK)
    }

    // ── User Assessments (subcollection — written by student, read self + teachers/admins) ──
    match /users/{userId}/assessments/{docId} {
      allow read: if isSelf(userId) || isTeacherOrAdmin();
      allow create, update: if isSelf(userId);
      allow delete: if isAdmin();
    }

    // ── User Grade Summary (subcollection — rolling averages maintained by student write) ──
    match /users/{userId}/gradeSummary/{docId} {
      allow read: if isSelf(userId) || isTeacherOrAdmin();
      allow create, update: if isSelf(userId);
      allow delete: if isAdmin();
    }

    // Leaderboard collection - publicly readable, written only by backend
    match /leaderboard/{docId} {
      allow read: if isSignedIn();
      allow write: if false;  // Backend/admin only via firebase-admin
    }

    match /users/{userId}/settings/{settingsId} {
      allow read: if isSelf(userId) || isAdmin();
      allow create, update: if isSelf(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── FCM Tokens (per-user, per-device — used by Cloud Functions to fan out push) ──
    // Each device writes its own token doc. Cloud Functions read with the
    // Admin SDK (bypasses rules), so we only need to scope client access here.
    match /users/{userId}/fcmTokens/{tokenId} {
      allow read: if isSelf(userId) || isAdmin();
      allow create, update, delete: if isSelf(userId);
    }

    // ── Daily Rewards (users can only claim their own, must change lastClaimedDate) ──
    match /users/{userId}/dailyRewards/{rewardId} {
      allow read: if isSelf(userId) || isTeacherOrAdmin();
      allow create: if isSelf(userId);
      allow update: if isSelf(userId)
                    && request.resource.data.lastClaimedDate != resource.data.lastClaimedDate;
      allow delete: if isAdmin();
    }

    // ── Login Streak Rewards (parallel system — fixed 7-day cycle) ──
    match /users/{userId}/loginStreakRewards/{docId} {
      allow read: if isSelf(userId) || isTeacherOrAdmin();
      allow create: if isSelf(userId);
      allow update: if isSelf(userId)
                    && request.resource.data.lastClaimedDate != resource.data.lastClaimedDate;
      allow delete: if isAdmin();
    }

    // ── Competency Matrix (subcollection under users) ──
    match /users/{userId}/competencyMatrix/{docId} {
      allow read: if isSelf(userId) || isTeacherOrAdmin();
      allow write: if isSelf(userId) || isTeacherOrAdmin();
    }

    // ── Quiz Results (subcollection under users) ──
    match /users/{userId}/quizResults/{docId} {
      allow read: if isSelf(userId) || isTeacherOrAdmin();
      allow write: if isSelf(userId) || isTeacherOrAdmin();
    }

    // ── Module Progress (subcollection under users) ──
    match /users/{userId}/moduleProgress/{docId} {
      allow read: if isSelf(userId) || isTeacherOrAdmin();
      allow write: if isSelf(userId) || isTeacherOrAdmin();
    }

    match /progress/{docId} {
      // Allow by document ID (docId == userId) or by userId field
      allow read: if isSignedIn() && (request.auth.uid == docId || ownerByField('userId')) || isTeacherOrAdmin();
      allow create, update: if isSignedIn() && (request.auth.uid == docId || ownerByField('userId')) || isTeacherOrAdmin();
      allow delete: if isAdmin();
    }

    match /xpActivities/{docId} {
      allow read: if isSignedIn() && (request.auth.uid == docId || ownerByField('userId')) || isTeacherOrAdmin();
      allow create, update: if isSignedIn() && (request.auth.uid == docId || ownerByField('userId')) || isTeacherOrAdmin();
      allow delete: if isAdmin();
    }

    match /achievements/{docId} {
      allow read: if isSignedIn() && (request.auth.uid == docId || ownerByField('userId')) || isTeacherOrAdmin();
      allow create, update: if isSignedIn() && (request.auth.uid == docId || ownerByField('userId')) || isTeacherOrAdmin();
      allow delete: if isAdmin();
    }

    match /notifications/{docId} {
      allow read: if isSignedIn() && (request.auth.uid == docId || ownerByField('userId')) || isTeacherOrAdmin();
      allow create, update: if isSignedIn() && (request.auth.uid == docId || ownerByField('userId')) || isTeacherOrAdmin();
      allow delete: if isSignedIn() && (request.auth.uid == docId || ownerByField('userId')) || isAdmin();
    }

    // ── Notifications subcollection (new structure) ─────────────────
    match /notifications/{userId}/items/{notificationId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
    }

    match /tasks/{docId} {
      allow read: if isSignedIn() && (request.auth.uid == docId || ownerByField('userId')) || isTeacherOrAdmin();
      allow create, update: if isSignedIn() && (request.auth.uid == docId || ownerByField('userId')) || isTeacherOrAdmin();
      allow delete: if isSignedIn() && (request.auth.uid == docId || ownerByField('userId')) || isAdmin();
    }

    match /chatSessions/{docId} {
      allow read: if isSignedIn() && (request.auth.uid == docId || ownerByField('userId')) || isTeacherOrAdmin();
      allow create, update: if isSignedIn() && (request.auth.uid == docId || ownerByField('userId')) || isTeacherOrAdmin();
      allow delete: if isSignedIn() && (request.auth.uid == docId || ownerByField('userId')) || isAdmin();
    }

    match /chatMessages/{docId} {
      allow read: if isSignedIn() && (request.auth.uid == docId || ownerByField('userId')) || isTeacherOrAdmin();
      allow create, update: if isSignedIn() && (request.auth.uid == docId || ownerByField('userId')) || isTeacherOrAdmin();
      allow delete: if isSignedIn() && (request.auth.uid == docId || ownerByField('userId')) || isAdmin();
    }

    match /friendRequests/{docId} {
      allow read: if isSignedIn() && (
        resource.data.senderId == request.auth.uid ||
        resource.data.receiverId == request.auth.uid ||
        isTeacherOrAdmin()
      );
      allow create, update: if isSignedIn() && (
        request.resource.data.senderId == request.auth.uid ||
        request.resource.data.receiverId == request.auth.uid ||
        isTeacherOrAdmin()
      );
      allow delete: if isSignedIn() && (
        resource.data.senderId == request.auth.uid ||
        resource.data.receiverId == request.auth.uid ||
        isAdmin()
      );
    }

    match /friendships/{docId} {
      allow read: if isSignedIn() && (
        resource.data.user1Id == request.auth.uid ||
        resource.data.user2Id == request.auth.uid ||
        isTeacherOrAdmin()
      );
      allow create, update: if isSignedIn() && (
        request.resource.data.user1Id == request.auth.uid ||
        request.resource.data.user2Id == request.auth.uid ||
        isTeacherOrAdmin()
      );
      allow delete: if isSignedIn() && (
        resource.data.user1Id == request.auth.uid ||
        resource.data.user2Id == request.auth.uid ||
        isAdmin()
      );
    }

    match /managedStudents/{studentId} {
      allow read: if isSelf(studentId) || isTeacherOrAdmin();
      allow create, update: if isTeacherOrAdmin();
      allow delete: if isAdmin();
    }

    // Subcollection: managedStudents/{studentId}/activityScores
    match /managedStudents/{studentId}/activityScores/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isTeacherOrAdmin();
      allow delete: if isTeacherOrAdmin();
    }

    // Subcollection: managedStudents/{studentId}/externalGrades
    match /managedStudents/{studentId}/externalGrades/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isTeacherOrAdmin();
      allow delete: if isTeacherOrAdmin();
    }

    match /classrooms/{classroomId} {
      allow read: if isAdmin() || (isTeacher() && (
        ownerInExisting('teacherId') ||
        ownerInExisting('ownerTeacherId') ||
        ownerInExisting('adviserTeacherId') ||
        ownerInExisting('managerId')
      ));
      allow create, update: if isAdmin() || (isTeacher() && (
        ownerInIncoming('teacherId') ||
        ownerInExisting('teacherId') ||
        ownerInIncoming('ownerTeacherId') ||
        ownerInExisting('ownerTeacherId') ||
        ownerInIncoming('managerId') ||
        ownerInExisting('managerId')
      ));
      allow delete: if isAdmin();
    }

    match /classSectionOwnership/{classSectionId} {
      allow read: if isAdmin() || (isTeacher() && (
        ownerInExisting('ownerTeacherId') ||
        ownerInExisting('managerId')
      ));
      allow create, update: if isAdmin() || (isTeacher() && (
        ownerInIncoming('ownerTeacherId') ||
        ownerInExisting('ownerTeacherId') ||
        ownerInIncoming('managerId') ||
        ownerInExisting('managerId')
      ));
      allow delete: if isAdmin();
    }

    match /classRecordImports/{importId} {
      allow read: if isAdmin() || (isTeacher() && ownerByField('teacherId'));
      allow create, update, delete: if false;
    }

    match /normalizedClassRecords/{recordId} {
      allow read: if isAdmin() || (isTeacher() && ownerByField('teacherId'));
      allow create, update, delete: if false;
    }

    match /accessAuditLogs/{auditId} {
      allow read: if isTeacherOrAdmin();
      allow create, update, delete: if false;
    }

    match /diagnosticResults/{docId} {
      // Temporarily permissive for debugging - allow students to read their own
      allow read: if isSignedIn() && (request.auth.uid == docId || isTeacherOrAdmin());
      allow create, update: if isSignedIn() && (request.auth.uid == docId || isTeacherOrAdmin());
      allow delete: if isSignedIn() && request.auth.uid == docId || isAdmin();
    }

    // ── Diagnostic Sessions (backend writes, students read their own) ──
    match /diagnosticSessions/{docId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.userId || isTeacherOrAdmin());
      allow create: if isSignedIn();  // Backend creates via firebase-admin, also allow student-initiated
      allow update, delete: if false;  // Backend only
    }
    // Assessment Results — students can read their own, backend writes
    match /assessmentResults/{studentId}/attempts/{attemptId} {
      allow read: if request.auth != null && request.auth.uid == studentId;
      allow write: if request.auth != null;
    }


    // ── Student Progress / Stats (written by backend after diagnostic) ──
    match /studentProgress/{userId} {
      allow read: if isSelf(userId) || isTeacherOrAdmin();
      allow create, update: if isSelf(userId) || isAdmin();
    }
    match /studentProgress/{userId}/stats/{docId} {
      allow read: if isSelf(userId) || isTeacherOrAdmin();
      allow create, update: if false;  // Backend only via firebase-admin
      allow delete: if isAdmin();
    }

    match /quizResults/{docId} {
      // Allow students to read their own by document ID
      allow read: if isSignedIn() && (request.auth.uid == docId || isTeacherOrAdmin());
      allow create, update: if isSignedIn() && (request.auth.uid == docId || isTeacherOrAdmin());
      allow delete: if isAdmin();
    }

    match /generatedQuizzes/{docId} {
      allow read: if isTeacherOrAdmin() || ownerByField('teacherId');
      allow create: if isTeacherOrAdmin() || ownerInIncoming('teacherId');
      allow update, delete: if isAdmin() || ownerInExisting('teacherId');
    }

    match /quizAssignments/{docId} {
      allow read: if isTeacherOrAdmin() || ownerByField('teacherId') || ownerByField('lrn');
      allow create: if isTeacherOrAdmin() || ownerInIncoming('teacherId');
      allow update, delete: if isAdmin() || ownerInExisting('teacherId');
    }

    match /attendance/{docId} {
      allow read: if isTeacherOrAdmin() || ownerByField('studentId');
      allow create, update: if isTeacherOrAdmin();
      allow delete: if isAdmin();
    }

    match /curriculumContent/{docId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /contentAuditLog/{docId} {
      allow read: if isTeacherOrAdmin();
      allow create, update, delete: if false;
    }

    match /deepDiagnosticAssignments/{docId} {
      allow read: if isTeacherOrAdmin() || ownerByField('lrn');
      allow create, update, delete: if false;
    }

    match /recommendationLogs/{docId} {
      allow read: if isTeacherOrAdmin() || ownerByField('lrn') || ownerByField('userId');
      allow create, update, delete: if false;
    }

    match /learnerMasterySnapshots/{docId} {
      allow read: if isTeacherOrAdmin() || ownerByField('lrn') || ownerByField('userId');
      allow create, update, delete: if false;
    }

    match /quizBattleQueue/{docId} {
      allow read: if isSignedIn() && (request.auth.uid == docId || ownerByField('studentId')) || isTeacherOrAdmin();
      allow create, update, delete: if isSignedIn() && (request.auth.uid == docId || ownerByField('studentId'));
    }

    match /quizBattleHistory/{docId} {
      allow read: if isSignedIn() && (request.auth.uid == docId || ownerByField('studentId')) || isTeacherOrAdmin();
      allow create, update, delete: if false;
    }

    match /quizBattleMatches/{docId} {
      allow read: if isSignedIn() && (
        resource.data.playerAId == request.auth.uid ||
        resource.data.playerBId == request.auth.uid ||
        isTeacherOrAdmin()
      );
      allow create, update, delete: if false;
    }

    match /quizBattleRooms/{docId} {
      allow read: if isSignedIn() && (
        resource.data.ownerStudentId == request.auth.uid ||
        (resource.data.participantIds is list && request.auth.uid in resource.data.participantIds) ||
        isTeacherOrAdmin()
      );
      allow create, update, delete: if false;
    }

    match /studentBattleStats/{userId} {
      allow read: if isSelf(userId) || isTeacherOrAdmin();
      allow create, update, delete: if false;
    }

    match /studentBattleLeaderboard/{docId} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    match /progressionAuditLog/{docId} {
      allow read: if isTeacherOrAdmin() || ownerByField('lrn') || ownerByField('userId');
      allow create, update, delete: if false;
    }

    // ── Video search cache (read for all authenticated users) ──
    match /video_cache/{docId} {
      allow read: if isSignedIn();
      allow write: if false;  // Backend-only writes via firebase-admin
    }

    // ── Question bank (read for all authenticated users) ──
    match /question_bank/{gradeLevel}/{topic}/{questionId} {
      allow read: if isSignedIn();
      allow write: if false; // Backend-only via firebase-admin
    }

    // ── PDF processing status (read for teachers/admins) ──
    match /pdf_processing_status/{docId} {
      allow read: if isTeacherOrAdmin();
      allow write: if false; // Backend-only
    }

    // ── Quiz battle sessions (read for participants) ──
    match /quiz_battle_sessions/{sessionId} {
      allow read: if isSignedIn() && resource.data.player_ids.hasAny([request.auth.uid]);
      allow write: if false; // Backend-only
    }

    // ── Rate limit tracking (Cloud Functions write only) ──
    match /_ratelimits/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if false;  // Cloud Functions only via service account
    }
    match /_ratelimits/{uid}/{functionName} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if false;  // Cloud Functions only
    }

    // ── Rate limit analytics (read for admins only) ──
    match /_analytics/rateLimitHits/{uid} {
      allow read: if isAdmin();
      allow write: if false;  // Frontend only
    }

    // ── Assessments (student's own assessment data) ──
    match /assessments/{uid} {
      allow read: if isSelf(uid) || isTeacherOrAdmin();
      allow create, update: if isSelf(uid) || isAdmin();
      allow delete: if isSignedIn() && request.auth.uid == uid || isAdmin();
    }

    match /assessments/{uid}/attempts/{attemptId} {
      allow read: if isSelf(uid) || isTeacherOrAdmin();
      allow create, update: if isSelf(uid) || isAdmin();
      allow delete: if isSignedIn() && request.auth.uid == uid || isAdmin();
    }

    // ── Competency Profiles (student's competency tracking) ──
    match /competencyProfiles/{uid} {
      allow read: if isSelf(uid) || isTeacherOrAdmin();
      allow create, update: if isSelf(uid) || isTeacherOrAdmin() || isAdmin();
      allow delete: if isSignedIn() && request.auth.uid == uid || isAdmin();
    }

    // ── Class Assessments (teacher view of class assessment summaries) ──
    match /classAssessments/{classId} {
      allow read: if isTeacherOrAdmin();
      allow create, update: if isTeacherOrAdmin() || isAdmin();
      allow delete: if isAdmin();
    }

    match /classAssessments/{classId}/students/{uid} {
      allow read: if resource.data.teacherUid == request.auth.uid || isAdmin();
      allow write: if isAdmin();
    }
    // ── Platform Config (admin-managed subject availability) ──
    match /platformConfig/{docId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // ── Module Activities (student activity tracking — self write, self + teachers/admins read) ──
    match /moduleActivities/{docId} {
      allow read: if isSignedIn() && (request.auth.uid == docId || ownerByField('userId')) || isTeacherOrAdmin();
      allow create: if isSignedIn() && ownerInIncoming('userId');
      allow update, delete: if isSignedIn() && (request.auth.uid == docId || ownerByField('userId')) || isAdmin();
    }

    // ── Platform Settings (admin-managed, publicly readable) ──
    match /settings/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── AI Usage Logs (written by backend/admin SDK, read by admins) ──
    match /aiUsageLogs/{docId} {
      allow read: if isAdmin() || isTeacherOrAdmin();
      allow write: if false; // Backend only via firebase-admin
    }

    // ── Modules (DepEd curriculum + teacher-uploaded modules) ──
    // moduleType field: "deped" (or absent) = curriculum, "teacher_uploaded" = teacher-created
    // Teachers can create teacher_uploaded modules; all authenticated users can read all modules
    match /modules/{moduleId} {
      allow read: if isSignedIn();
      allow create: if isTeacherOrAdmin();
      allow update, delete: if isTeacherOrAdmin() && (
        ownerInExisting('uploadedBy') || ownerInExisting('teacherId')
      );
    }

// ── Class Records (teacher-uploaded student grade data) ──
    match /classRecords/{teacherUid} {
      allow read: if isAdmin() || (isTeacher() && request.auth.uid == teacherUid);
      allow write: if false;
      
      match /uploads/{uploadId} {
        allow read: if isAdmin() || (isTeacher() && teacherUid == request.auth.uid);
        allow write: if false;
      }
      
      match /sections/{sectionId}/students/{lrn} {
        allow read: if isAdmin() || (isTeacher() && teacherUid == request.auth.uid) || (isSignedIn() && resource.data.lrn == lrn);
        allow write: if false;
      }
    }
    // Tutor check-in messages (backend writes, student reads own)
    match /tutorCheckins/{uid} {
      match /messages/{msgId} {
        allow read: if isSelf(uid);
        allow create, update, delete: if false;
      }
    }

    // AI-generated quizzes from modules
    match /quizzes/{quizId} {
      allow read: if isSignedIn();
      allow create: if isTeacherOrAdmin();
      allow update, delete: if isTeacherOrAdmin() && ownerInExisting('teacherId');
    }

    // Personalized student recommendations (backend writes, student reads own)
    match /studentRecommendations/{uid} {
      allow read: if isSelf(uid);
      allow write: if false;
    }

    // Weekly teacher digests (backend writes, teacher reads own)
    match /teacherDigests/{teacherId} {
      allow read: if isSelf(teacherId);
      allow write: if false;
    }

    // Analytics cache (frontend writes, self read)
    match /analyticsCache/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isTeacherOrAdmin();
    }

    // ── Calendar Events (user-owned) ──
    match /calendarEvents/{docId} {
      allow read: if isSignedIn() && ownerByField('userId') || isTeacherOrAdmin();
      allow create: if isSignedIn() && ownerInIncoming('userId');
      allow update, delete: if isSignedIn() && ownerByField('userId') || isAdmin();
    }

    // ── Tutor Memory (student-specific AI tutoring memory) ──
    // Profile memory: long-term student profile data
    match /users/{uid}/tutorMemory/profile/{docId} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow create, update: if isSignedIn() && request.auth.uid == uid;
      allow delete: if isAdmin();
    }
    // Session memory: episodic summaries of tutoring sessions
    match /users/{uid}/tutorMemory/sessions/{sessionId} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isTeacherOrAdmin());
      allow create, update: if isSignedIn() && request.auth.uid == uid;
      allow delete: if isAdmin();
    }
    // Working memory: active session state (current topic, problem, turns)
    match /users/{uid}/tutorMemory/working/{docId} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    // Deny-by-default for unknown collections.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
