rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function role() {
      return isSignedIn() ? userDoc().data.role : null;
    }

    function isAdmin() {
      return isSignedIn() && role() == 'admin';
    }

    function isTeacher() {
      return isSignedIn() && role() == 'teacher';
    }

    function isStudent() {
      return isSignedIn() && role() == 'student';
    }

    function isTeacherOrAdmin() {
      return isTeacher() || isAdmin();
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function ownerInExisting(field) {
      return resource != null && resource.data[field] == request.auth.uid;
    }

    function ownerInIncoming(field) {
      return request.resource != null && request.resource.data[field] == request.auth.uid;
    }

    function ownerByField(field) {
      return isSignedIn() && (ownerInExisting(field) || ownerInIncoming(field));
    }

    match /users/{userId} {
      allow create: if isSelf(userId);
      allow read: if isSelf(userId) || isTeacherOrAdmin();
      allow update: if isSelf(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /users/{userId}/settings/{settingsId} {
      allow read: if isSelf(userId) || isAdmin();
      allow create, update: if isSelf(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /progress/{docId} {
      allow read: if ownerByField('userId') || isTeacherOrAdmin();
      allow create, update: if ownerByField('userId') || isTeacherOrAdmin();
      allow delete: if isAdmin();
    }

    match /xpActivities/{docId} {
      allow read: if ownerByField('userId') || isTeacherOrAdmin();
      allow create, update: if ownerByField('userId') || isTeacherOrAdmin();
      allow delete: if isAdmin();
    }

    match /achievements/{docId} {
      allow read: if ownerByField('userId') || isTeacherOrAdmin();
      allow create, update: if ownerByField('userId') || isTeacherOrAdmin();
      allow delete: if isAdmin();
    }

    match /notifications/{docId} {
      allow read: if ownerByField('userId') || isTeacherOrAdmin();
      allow create, update: if ownerByField('userId') || isTeacherOrAdmin();
      allow delete: if ownerByField('userId') || isAdmin();
    }

    // ── Notifications subcollection (new structure) ─────────────────
    match /notifications/{userId}/items/{notificationId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
    }

    match /tasks/{docId} {
      allow read: if ownerByField('userId') || isTeacherOrAdmin();
      allow create, update: if ownerByField('userId') || isTeacherOrAdmin();
      allow delete: if ownerByField('userId') || isAdmin();
    }

    match /chatSessions/{docId} {
      allow read: if ownerByField('userId') || isTeacherOrAdmin();
      allow create, update: if ownerByField('userId') || isTeacherOrAdmin();
      allow delete: if ownerByField('userId') || isAdmin();
    }

    match /chatMessages/{docId} {
      allow read: if ownerByField('userId') || isTeacherOrAdmin();
      allow create, update: if ownerByField('userId') || isTeacherOrAdmin();
      allow delete: if ownerByField('userId') || isAdmin();
    }

    match /friendRequests/{docId} {
      allow read: if isSignedIn() && (
        resource.data.senderId == request.auth.uid ||
        resource.data.receiverId == request.auth.uid ||
        isTeacherOrAdmin()
      );
      allow create, update: if isSignedIn() && (
        request.resource.data.senderId == request.auth.uid ||
        request.resource.data.receiverId == request.auth.uid ||
        isTeacherOrAdmin()
      );
      allow delete: if isSignedIn() && (
        resource.data.senderId == request.auth.uid ||
        resource.data.receiverId == request.auth.uid ||
        isAdmin()
      );
    }

    match /friendships/{docId} {
      allow read: if isSignedIn() && (
        resource.data.user1Id == request.auth.uid ||
        resource.data.user2Id == request.auth.uid ||
        isTeacherOrAdmin()
      );
      allow create, update: if isSignedIn() && (
        request.resource.data.user1Id == request.auth.uid ||
        request.resource.data.user2Id == request.auth.uid ||
        isTeacherOrAdmin()
      );
      allow delete: if isSignedIn() && (
        resource.data.user1Id == request.auth.uid ||
        resource.data.user2Id == request.auth.uid ||
        isAdmin()
      );
    }

    match /managedStudents/{studentId} {
      allow read: if isSelf(studentId) || isTeacherOrAdmin();
      allow create, update: if isTeacherOrAdmin();
      allow delete: if isAdmin();
    }

    match /classrooms/{classroomId} {
      allow read: if isAdmin() || (isTeacher() && (
        ownerInExisting('teacherId') ||
        ownerInExisting('ownerTeacherId') ||
        ownerInExisting('adviserTeacherId') ||
        ownerInExisting('managerId')
      ));
      allow create, update: if isAdmin() || (isTeacher() && (
        ownerInIncoming('teacherId') ||
        ownerInExisting('teacherId') ||
        ownerInIncoming('ownerTeacherId') ||
        ownerInExisting('ownerTeacherId') ||
        ownerInIncoming('managerId') ||
        ownerInExisting('managerId')
      ));
      allow delete: if isAdmin();
    }

    match /classSectionOwnership/{classSectionId} {
      allow read: if isAdmin() || (isTeacher() && (
        ownerInExisting('ownerTeacherId') ||
        ownerInExisting('managerId')
      ));
      allow create, update: if isAdmin() || (isTeacher() && (
        ownerInIncoming('ownerTeacherId') ||
        ownerInExisting('ownerTeacherId') ||
        ownerInIncoming('managerId') ||
        ownerInExisting('managerId')
      ));
      allow delete: if isAdmin();
    }

    match /classRecordImports/{importId} {
      allow read: if isAdmin() || (isTeacher() && ownerByField('teacherId'));
      allow create, update, delete: if false;
    }

    match /normalizedClassRecords/{recordId} {
      allow read: if isAdmin() || (isTeacher() && ownerByField('teacherId'));
      allow create, update, delete: if false;
    }

    match /accessAuditLogs/{auditId} {
      allow read: if isTeacherOrAdmin();
      allow create, update, delete: if false;
    }

    match /diagnosticResults/{docId} {
      allow read: if isTeacherOrAdmin() || ownerByField('studentId');
      allow create, update: if isTeacherOrAdmin() || ownerByField('studentId');
      allow delete: if isAdmin();
    }

    match /quizResults/{docId} {
      allow read: if isTeacherOrAdmin() || ownerByField('studentId');
      allow create, update: if isTeacherOrAdmin() || ownerByField('studentId');
      allow delete: if isAdmin();
    }

    match /generatedQuizzes/{docId} {
      allow read: if isTeacherOrAdmin() || ownerByField('teacherId');
      allow create: if isTeacherOrAdmin() || ownerInIncoming('teacherId');
      allow update, delete: if isAdmin() || ownerInExisting('teacherId');
    }

    match /quizAssignments/{docId} {
      allow read: if isTeacherOrAdmin() || ownerByField('teacherId') || ownerByField('lrn');
      allow create: if isTeacherOrAdmin() || ownerInIncoming('teacherId');
      allow update, delete: if isAdmin() || ownerInExisting('teacherId');
    }

    match /attendance/{docId} {
      allow read: if isTeacherOrAdmin() || ownerByField('studentId');
      allow create, update: if isTeacherOrAdmin();
      allow delete: if isAdmin();
    }

    match /curriculumContent/{docId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /contentAuditLog/{docId} {
      allow read: if isTeacherOrAdmin();
      allow create, update, delete: if false;
    }

    match /deepDiagnosticAssignments/{docId} {
      allow read: if isTeacherOrAdmin() || ownerByField('lrn');
      allow create, update, delete: if false;
    }

    match /recommendationLogs/{docId} {
      allow read: if isTeacherOrAdmin() || ownerByField('lrn') || ownerByField('userId');
      allow create, update, delete: if false;
    }

    match /learnerMasterySnapshots/{docId} {
      allow read: if isTeacherOrAdmin() || ownerByField('lrn') || ownerByField('userId');
      allow create, update, delete: if false;
    }

    match /quizBattleQueue/{docId} {
      allow read: if ownerByField('studentId') || isTeacherOrAdmin();
      allow create, update, delete: if ownerByField('studentId');
    }

    match /quizBattleHistory/{docId} {
      allow read: if ownerByField('studentId') || isTeacherOrAdmin();
      allow create, update, delete: if false;
    }

    match /quizBattleMatches/{docId} {
      allow read: if isSignedIn() && (
        resource.data.playerAId == request.auth.uid ||
        resource.data.playerBId == request.auth.uid ||
        isTeacherOrAdmin()
      );
      allow create, update, delete: if false;
    }

    match /quizBattleRooms/{docId} {
      allow read: if isSignedIn() && (
        resource.data.ownerStudentId == request.auth.uid ||
        (resource.data.participantIds is list && request.auth.uid in resource.data.participantIds) ||
        isTeacherOrAdmin()
      );
      allow create, update, delete: if false;
    }

    match /studentBattleStats/{userId} {
      allow read: if isSelf(userId) || isTeacherOrAdmin();
      allow create, update, delete: if false;
    }

    match /studentBattleLeaderboard/{docId} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    match /progressionAuditLog/{docId} {
      allow read: if isTeacherOrAdmin() || ownerByField('lrn') || ownerByField('userId');
      allow create, update, delete: if false;
    }

    // ── Video search cache (read for all authenticated users) ──
    match /video_cache/{docId} {
      allow read: if isSignedIn();
      allow write: if false;  // Backend-only writes via firebase-admin
    }

    // ── Question bank (read for all authenticated users) ──
    match /question_bank/{gradeLevel}/{topic}/{questionId} {
      allow read: if isSignedIn();
      allow write: if false; // Backend-only via firebase-admin
    }

    // ── PDF processing status (read for teachers/admins) ──
    match /pdf_processing_status/{docId} {
      allow read: if isTeacherOrAdmin();
      allow write: if false; // Backend-only
    }

    // ── Quiz battle sessions (read for participants) ──
    match /quiz_battle_sessions/{sessionId} {
      allow read: if isSignedIn() && resource.data.player_ids.hasAny([request.auth.uid]);
      allow write: if false; // Backend-only
    }

    // ── Assessments (student's own assessment data) ──
    match /assessments/{uid} {
      allow read: if isSelf(uid) || isTeacherOrAdmin();
      allow create, update: if isSelf(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    match /assessments/{uid}/attempts/{attemptId} {
      allow read: if isSelf(uid) || isTeacherOrAdmin();
      allow create, update: if isSelf(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Competency Profiles (student's competency tracking) ──
    match /competencyProfiles/{uid} {
      allow read: if isSelf(uid) || isTeacherOrAdmin();
      allow create, update: if isSelf(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Class Assessments (teacher view of class assessment summaries) ──
    match /classAssessments/{classId} {
      allow read: if isTeacherOrAdmin();
      allow create, update: if isTeacherOrAdmin() || isAdmin();
      allow delete: if isAdmin();
    }

    match /classAssessments/{classId}/students/{uid} {
      allow read: if resource.data.teacherUid == request.auth.uid || isAdmin();
      allow write: if isAdmin();
    }
    // Deny-by-default for unknown collections.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
