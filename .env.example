# Firebase Configuration
# Get these values from Firebase Console → Project Settings → Your apps
# https://console.firebase.google.com/

# IMPORTANT: Copy this file to .env.local and fill in your actual values
# Never commit .env.local to version control!

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id
# Use the exact Realtime Database URL from Firebase Console (e.g. https://<db-name>.firebasedatabase.app)
VITE_FIREBASE_DATABASE_URL=https://your_project_id-default-rtdb.firebaseio.com

# Hugging Face model used for AI monitoring (client-safe, no token)
VITE_HF_MODEL_ID=Qwen/QwQ-32B
VITE_HF_USERNAME=Deign86

# Backend API URL
VITE_API_URL=https://deign86-mathpulse-api-v3test.hf.space

# Pilot rollout controls for import-grounded generation (frontend)
VITE_ENABLE_IMPORT_GROUNDED_QUIZ=true
VITE_ENABLE_IMPORT_GROUNDED_LESSON=true
VITE_ENABLE_IMPORT_GROUNDED_FEEDBACK_EVENTS=true
VITE_ENABLE_ASYNC_GENERATION=true

# Chat stream watchdogs (frontend fallback protection)
VITE_CHAT_STREAM_IDLE_TIMEOUT_MS=20000
VITE_CHAT_STREAM_TOTAL_TIMEOUT_MS=120000

# Optional local Firebase Functions emulator routing
VITE_USE_FUNCTIONS_EMULATOR=false
VITE_FUNCTIONS_EMULATOR_HOST=127.0.0.1
VITE_FUNCTIONS_EMULATOR_PORT=5001

# Strictly fail match start when generation audit does not confirm AI source
VITE_QUIZ_BATTLE_STRICT_GENERATION_AUDIT=false

# ════════════════════════════════════════════════════════════════════
# THREE-MODEL ARCHITECTURE
# ════════════════════════════════════════════════════════════════════
# Model 1 — Generation (Free Tier)
#   Qwen/QwQ-32B
#   Used for: chat, lightweight tasks, all fallback routes, dev profile
#   Endpoint: Free HF Inference — no billing
# Model 2 — Generation (HF Pro)
#   Qwen/Qwen3-235B-A22B
#   Used for: rag_lesson, rag_problem, quiz_generation (prod profile)
#   Endpoint: HF Pro Inference — billed usage
# Model 3 — Embedding (Fixed Infrastructure)
#   BAAI/bge-small-en-v1.5
#   Used for: RAG retrieval — curriculum vectorstore ingestion and search
#   Endpoint: Free HF Inference — not swappable via admin panel
# ════════════════════════════════════════════════════════════════════
# GENERATION MODEL PROFILE (controls Models 1 and 2)
# ════════════════════════════════════════════════════════════════════
# OPTION A — Profile-based (startup default)
# MODEL_PROFILE=dev       # All tasks → Qwen/QwQ-32B (free, no billing)
# MODEL_PROFILE=prod      # RAG + quiz → Qwen3-235B-A22B, chat → QwQ-32B
# MODEL_PROFILE=budget    # All tasks → Qwen3-32B (moderate cost)
#
MODEL_PROFILE=dev

# OPTION B — Fine-grained override (beats MODEL_PROFILE)
# INFERENCE_MODEL_ID=Qwen/QwQ-32B
# INFERENCE_CHAT_MODEL_ID=Qwen/QwQ-32B
# HF_QUIZ_MODEL_ID=Qwen/QwQ-32B
# HF_RAG_MODEL_ID=Qwen/Qwen3-235B-A22B

# OPTION C — Qwen lock (beats everything including admin panel)
# INFERENCE_ENFORCE_QWEN_ONLY=true
# INFERENCE_QWEN_LOCK_MODEL=Qwen/QwQ-32B

# OPTION D — Admin Panel (runtime, no restart needed)
# Use Admin Settings → Model Configuration to switch profiles live.

INFERENCE_PROVIDER=hf_inference
INFERENCE_GPU_PROVIDER=hf_inference
INFERENCE_CPU_PROVIDER=hf_inference

HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ════════════════════════════════════════════════════════════════════
# EMBEDDING MODEL (Model 3 — Fixed — do not change without re-ingesting vectorstore)
# ════════════════════════════════════════════════════════════════════
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
CURRICULUM_VECTORSTORE_DIR=datasets/vectorstore
