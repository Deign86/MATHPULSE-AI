# Firebase Configuration
# Get these values from Firebase Console → Project Settings → Your apps
# https://console.firebase.google.com/

# IMPORTANT: Copy this file to .env.local and fill in your actual values
# Never commit .env.local to version control!

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Backend API URL
VITE_API_URL=your_api_url

# Pilot rollout controls for import-grounded generation (frontend)
VITE_ENABLE_IMPORT_GROUNDED_QUIZ=true
VITE_ENABLE_IMPORT_GROUNDED_LESSON=true
VITE_ENABLE_IMPORT_GROUNDED_FEEDBACK_EVENTS=true
VITE_ENABLE_ASYNC_GENERATION=true

# Staging-only Hugging Face vs vLLM model viability tester
# Keep these OFF in production by default.
VITE_APP_ENV=production
VITE_ENABLE_STAGING_MODEL_TEST=false

# Base/original model via Hugging Face Inference
# Hard-locked in staging code:
# - HF base URL: https://router.huggingface.co/v1
# - HF base model: Qwen/Qwen2.5-7B-Instruct
VITE_HF_API_KEY=

# Candidate/fine-tuned model via vLLM
VITE_VLLM_BASE_URL=
VITE_VLLM_MODEL=
VITE_VLLM_API_KEY=

# Optional future comparison mode (not used in first cut)
VITE_VLLM_BASE_URL_BASELINE=
VITE_VLLM_BASE_URL_CANDIDATE=

# Optional lightweight quick-check latency threshold in ms
VITE_STAGING_QUICKCHECK_MAX_LATENCY_MS=12000

# Optional staging request controls (useful for slow ngrok/vLLM endpoints)
VITE_STAGING_REQUEST_TIMEOUT_MS=120000
VITE_STAGING_HEALTH_TIMEOUT_MS=10000
VITE_STAGING_REQUEST_RETRY_COUNT=0
VITE_STAGING_REQUEST_RETRY_DELAY_MS=1250

# Optional Qwen2.5-7B-Instruct tuned generation defaults for staging UI
VITE_STAGING_QWEN_DEFAULT_TEMPERATURE=0.2
VITE_STAGING_QWEN_DEFAULT_MAX_TOKENS=256
VITE_STAGING_QWEN_DEFAULT_TOP_P=0.8
