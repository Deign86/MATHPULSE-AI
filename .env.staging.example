# Staging environment sample for Model Viability Tester
# Copy to .env.local (or .env.staging) for staging branch testing.

VITE_APP_ENV=staging
VITE_ENABLE_STAGING_MODEL_TEST=true

# Base/original model via Hugging Face Inference
VITE_HF_BASE_URL=https://router.huggingface.co/v1
VITE_HF_BASE_MODEL=YOUR_BASE_MODEL_ID
VITE_HF_API_KEY=

# Candidate/fine-tuned model via vLLM
VITE_VLLM_BASE_URL=https://your-vllm-endpoint
VITE_VLLM_MODEL=Deign86/deped-math-qwen2.5-7b-deped-math-merged
VITE_VLLM_API_KEY=

# Optional: reserved for future side-by-side comparison mode
VITE_VLLM_BASE_URL_BASELINE=
VITE_VLLM_BASE_URL_CANDIDATE=

# Optional: lightweight quick check latency threshold in ms
VITE_STAGING_QUICKCHECK_MAX_LATENCY_MS=12000
