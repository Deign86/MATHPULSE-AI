            "dev": "vite",
            "dev:open": "vite --open",
            "dev:debug:plugin-transform": "vite --debug plugin-transform",
            "dev:debug:transform": "vite --debug transform",
            "dev:debug:css-probe": "cross-env VITE_CSS_TIMING_PROBE=1 vite --debug transform",
            "dev:profile": "vite --profile --open",
            "build": "vite build",
            "bones:build": "npx boneyard-js build",
            "bones:capture": "npx boneyard-js capture",
            "test": "vitest run --passWithNoTests",
            "test:watch": "vitest",
            "lint": "eslint src --ext .ts,.tsx",
            "lint:fix": "eslint src --ext .ts,.tsx --fix",
            "format": "prettier --write src/**/*.{ts,tsx}",
            "typecheck": "tsc --noEmit",
            "typecheck:backend": "node scripts/backend-gate.mjs typecheck",
            "check:backend": "node scripts/backend-gate.mjs check",
            "sync:models": "python scripts/sync_models_config.py",
            "predev": "npm run sync:models && npm run check:backend",
            "test:e2e": "npx playwright test",
            "check:backend:quick": "node scripts/backend-gate.mjs quick"
      },
      "overrides": {
            "protobufjs": ">=7.5.5"
      }
